{
  "openapi": "3.0.3",
  "info": {
    "title": "My Portfolio API",
    "description": "Public API for the portfolio: comments, contact, blog posts, and projects.",
    "version": "1.0.0",
    "license": { "name": "MIT" }
  },
  "servers": [{ "url": "/" }],
  "paths": {
    "/comments": {
      "get": {
        "summary": "List approved comments",
        "operationId": "listComments",
        "tags": ["Comments"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } }
        ],
        "responses": {
          "200": { "description": "HTML partial (HTMX) with approved comments" }
        }
      },
      "post": {
        "summary": "Submit a comment (OAuth required)",
        "operationId": "createComment",
        "tags": ["Comments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": { "type": "string" },
                  "parent_id": { "type": "integer" }
                },
                "required": ["content"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Comment queued for moderation" },
          "401": { "description": "OAuth login required" }
        }
      }
    },
    "/contact": {
      "post": {
        "summary": "Send a contact message",
        "operationId": "submitContact",
        "tags": ["Contact"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "name":    { "type": "string" },
                  "email":   { "type": "string", "format": "email" },
                  "message": { "type": "string" }
                },
                "required": ["name", "email", "message"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Message delivered" },
          "422": { "description": "Validation error" }
        }
      }
    },
    "/blog": {
      "get": {
        "summary": "Blog post list page",
        "operationId": "listBlogPosts",
        "tags": ["Blog"],
        "responses": { "200": { "description": "HTML page" } }
      }
    },
    "/blog/{slug}": {
      "get": {
        "summary": "Blog post detail",
        "operationId": "getBlogPost",
        "tags": ["Blog"],
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "HTML page" },
          "404": { "description": "Post not found" }
        }
      }
    },
    "/livez": {
      "get": {
        "summary": "Liveness probe",
        "operationId": "liveness",
        "tags": ["Health"],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/readyz": {
      "get": {
        "summary": "Readiness probe",
        "operationId": "readiness",
        "tags": ["Health"],
        "responses": {
          "200": { "description": "Ready" },
          "503": { "description": "Not ready" }
        }
      }
    }
  }
}
